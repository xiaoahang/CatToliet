{
  "name": "app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "install:deps": "powershell -ExecutionPolicy Bypass -File ./scripts/install.ps1",
    "install:deps:clean": "powershell -ExecutionPolicy Bypass -File ./scripts/install.ps1 -Clean",
    "start": "powershell -ExecutionPolicy Bypass -File ./scripts/dev.ps1",
    "deploy": "powershell -ExecutionPolicy Bypass -File ./scripts/deploy.ps1",
    "deploy:local": "powershell -ExecutionPolicy Bypass -File ./scripts/deploy.ps1 -Target local"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@types/three": "^0.184.1",
    "tailwindcss": "^4.2.4",
    "three": "^0.184.0",
    "vue": "^3.5.32",
    "vue-router": "^5.0.6"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/tsconfig": "^0.9.1",
    "typescript": "~6.0.2",
    "vite": "^8.0.10",
    "vue-tsc": "^3.2.7"
  }
}